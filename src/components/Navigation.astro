---
import { safeFetch } from "../lib/sanity";

const settings = await safeFetch(`*[_type == "siteSettings"][0]{ navItems, title }`);
const navItems = settings?.navItems ?? [
  { label: "About", href: "/about" },
  { label: "Services", href: "/services" },
  { label: "Resources", href: "/resources" },
  { label: "Contact", href: "/contact" },
];
const siteTitle = settings?.title ?? "Jamie Counselling";
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-bg/92 backdrop-blur-lg border-b border-border/50">
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="group flex items-center gap-2">
      <!-- Leaf mark -->
      <div class="w-8 h-8 rounded-full bg-accent flex items-center justify-center group-hover:bg-accent-dark transition-colors duration-300">
        <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 3c-4 4-7 8-7 13a7 7 0 0014 0c0-5-3-9-7-13z" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <span class="font-heading text-lg text-text-primary font-medium">{siteTitle}</span>
    </a>

    <!-- Desktop -->
    <div class="hidden md:flex items-center gap-1">
      {navItems.map((item: { label: string; href: string }) => (
        <a
          href={item.href}
          class:list={[
            "px-4 py-2 rounded-full text-[13px] font-semibold tracking-wide transition-all duration-200",
            currentPath === item.href
              ? "bg-accent/10 text-accent-dark"
              : "text-text-muted hover:text-text-primary hover:bg-surface/80",
          ]}
        >
          {item.label}
        </a>
      ))}
    </div>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="md:hidden w-9 h-9 rounded-full bg-surface flex items-center justify-center"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg class="w-4 h-4 text-text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7h16M4 12h10M4 17h14"/>
      </svg>
    </button>
  </nav>
</header>

<!-- Mobile menu -->
<div id="mobile-menu" class="hidden fixed inset-0 z-[60] bg-bg flex flex-col">
  <!-- Mobile header -->
  <div class="px-6 h-16 flex items-center justify-between border-b border-border/50">
    <span class="font-heading text-lg text-text-primary font-medium">{siteTitle}</span>
    <button id="mobile-menu-close" class="w-9 h-9 rounded-full bg-surface flex items-center justify-center">
      <svg class="w-4 h-4 text-text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <!-- Mobile links -->
  <div class="flex-1 flex flex-col justify-center px-8 gap-2">
    {navItems.map((item: { label: string; href: string }) => (
      <a
        href={item.href}
        class:list={[
          "font-heading text-3xl py-2 transition-colors",
          currentPath === item.href ? "text-accent-dark" : "text-text-primary"
        ]}
      >
        {item.label}
      </a>
    ))}
  </div>
</div>

<script>
  function initMobileMenu() {
    const btn = document.getElementById("mobile-menu-btn");
    const close = document.getElementById("mobile-menu-close");
    const menu = document.getElementById("mobile-menu");
    const open = () => {
      menu?.classList.remove("hidden");
      menu?.classList.add("flex");
      btn?.setAttribute("aria-expanded", "true");
      document.body.style.overflow = "hidden";
    };
    const shut = () => {
      menu?.classList.add("hidden");
      menu?.classList.remove("flex");
      btn?.setAttribute("aria-expanded", "false");
      document.body.style.overflow = "";
    };
    btn?.addEventListener("click", open);
    close?.addEventListener("click", shut);
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !menu?.classList.contains("hidden")) shut();
    });
  }
  initMobileMenu();
  document.addEventListener("astro:page-load", initMobileMenu);
</script>
