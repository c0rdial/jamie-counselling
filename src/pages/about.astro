---
import BaseLayout from "../layouts/BaseLayout.astro";
import { safeFetch } from "../lib/sanity";
import { PortableText } from "astro-portabletext";

const page = await safeFetch(
  `*[_type == "page" && slug.current == "about"][0]{ title, body, seoTitle, seoDescription }`
);
---

<BaseLayout
  title={page?.seoTitle ?? page?.title ?? "About — Jamie Counselling"}
  description={page?.seoDescription ?? "Get to know Jamie and her approach to counselling"}
>
  <section class="max-w-4xl mx-auto px-6 py-12 md:py-16">
    <!-- Header -->
    <div class="text-center mb-12">
      <p class="text-xs uppercase tracking-[0.2em] text-accent font-semibold mb-3 reveal">About me</p>
      <h1 class="font-heading text-4xl md:text-5xl text-text-primary leading-tight reveal" style="transition-delay: 80ms;">
        {page?.title ?? "Hi, I'm Jamie"}
      </h1>
    </div>

    {page?.body ? (
      <div class="prose prose-neutral max-w-3xl mx-auto text-text-body leading-relaxed reveal">
        <PortableText value={page.body} />
      </div>
    ) : (
      <!-- Placeholder content -->
      <div class="max-w-3xl mx-auto">
        <!-- Photo + intro -->
        <div class="grid grid-cols-1 md:grid-cols-5 gap-10 items-start mb-12">
          <div class="md:col-span-2 reveal">
            <div class="aspect-[3/4] rounded-2xl bg-gradient-to-br from-accent-pale via-surface-warm to-rose-pale relative overflow-hidden">
              <div class="absolute inset-0 flex flex-col items-center justify-center text-center p-6">
                <svg class="w-12 h-12 text-accent/25 mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                  <path d="M12 3c-4 4-7 8-7 13a7 7 0 0014 0c0-5-3-9-7-13z" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M12 3v18" stroke-linecap="round"/>
                </svg>
                <p class="text-xs text-accent/40 font-medium">Photo coming soon</p>
              </div>
              <div class="absolute inset-0 rounded-2xl border border-accent/10" />
            </div>
          </div>
          <div class="md:col-span-3 space-y-5">
            <p class="text-[17px] text-text-body leading-[1.8] reveal" style="transition-delay: 100ms;">
              I'm a Registered Clinical Counsellor (RCC) based in British Columbia. I work with adults who are navigating anxiety, grief, relationship challenges, and the big — and small — transitions that life brings.
            </p>
            <p class="text-[17px] text-text-body leading-[1.8] reveal" style="transition-delay: 180ms;">
              My approach is warm, collaborative, and grounded in evidence-based practices including CBT, ACT, and person-centered therapy. I believe therapy works best when you feel genuinely safe, seen, and supported — not when someone is handing you a worksheet.
            </p>
          </div>
        </div>

        <div class="divider-line max-w-xs mx-auto mb-12" />

        <!-- Values -->
        <div class="mb-12">
          <h2 class="font-heading text-2xl text-text-primary text-center mb-8 reveal">What I believe about therapy</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 reveal-stagger">
            <div class="reveal p-6 rounded-2xl bg-white/60 border border-border/50">
              <p class="font-heading text-lg text-text-primary mb-2">You are the expert on your own life</p>
              <p class="text-[15px] text-text-body leading-relaxed">I'm not here to tell you what to do. My role is to help you reconnect with your own wisdom, at your own pace.</p>
            </div>
            <div class="reveal p-6 rounded-2xl bg-white/60 border border-border/50">
              <p class="font-heading text-lg text-text-primary mb-2">Healing isn't linear</p>
              <p class="text-[15px] text-text-body leading-relaxed">There's no "right way" to grow. Some weeks feel like breakthroughs; others feel like standing still. Both are valid.</p>
            </div>
            <div class="reveal p-6 rounded-2xl bg-white/60 border border-border/50">
              <p class="font-heading text-lg text-text-primary mb-2">The relationship is the foundation</p>
              <p class="text-[15px] text-text-body leading-relaxed">Research consistently shows that the therapeutic relationship matters more than any specific technique. Feeling safe comes first.</p>
            </div>
            <div class="reveal p-6 rounded-2xl bg-white/60 border border-border/50">
              <p class="font-heading text-lg text-text-primary mb-2">Small shifts create big change</p>
              <p class="text-[15px] text-text-body leading-relaxed">Lasting transformation often starts with noticing — a pattern, a feeling, a choice you didn't realize you had.</p>
            </div>
          </div>
        </div>

        <!-- Qualifications -->
        <div class="text-center reveal">
          <h2 class="font-heading text-2xl text-text-primary mb-6">Education & Training</h2>
          <div class="max-w-lg mx-auto space-y-3 text-[15px] text-text-body">
            <p>Master of Arts in Counselling Psychology</p>
            <p>Registered Clinical Counsellor (RCC), BCACC</p>
            <p>Training in CBT, ACT, and Emotion-Focused Therapy</p>
          </div>
        </div>

        <!-- CTA -->
        <div class="text-center mt-12 reveal">
          <div class="divider-line max-w-xs mx-auto mb-10" />
          <p class="text-text-body text-[17px] mb-8">Curious if we'd be a good fit?</p>
          <a
            href="/contact"
            class="group inline-flex items-center gap-2 bg-accent text-white px-8 py-3.5 rounded-full text-sm font-semibold hover:bg-accent-dark transition-all duration-300 hover:shadow-lg hover:shadow-accent/20"
          >
            Get in touch
            <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
      </div>
    )}
  </section>
</BaseLayout>
